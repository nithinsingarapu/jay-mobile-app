{
  "expo": {
    "name": "JAY",
    "slug": "jay-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Jay-logo.png",
    "scheme": "jay",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/Jay-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/Jay-logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
